			"Media",
			"Auth",
			"Docker",
			"DIR",
			"Utils",
			"Typo",
			"Mermaid-Diagram",
			"TeamEndpoints",
        	"Env"
		]
	},
	"recommendations": [
    "Vue.volar",
    "ms-playwright.playwright"
  ]
}